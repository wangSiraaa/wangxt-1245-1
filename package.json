{
  "name": "railway-dangerous-goods-inspection",
  "version": "1.0.0",
  "private": true,
  "description": "铁路危险货物装载检查系统",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:frontend": "npm run start --workspace=frontend",
